<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>RECON-X Report — {{ title }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root {
  /* Dark mode professional palette */
  --bg-primary: #0A0E1A;
  --bg-secondary: #10141F;
  --bg-tertiary: #151B2B;
  --bg-hover: #1A2332;
  --border-primary: #1F2A3D;
  --border-secondary: #2A3548;
  --text-primary: #E8EDF5;
  --text-secondary: #B4BAC4;
  --text-tertiary: #8A9000;
  
  /* Accent colors */
  --accent-primary: #00D9FF;
  --accent-secondary: #A78BFA;
  --accent-tertiary: #34D399;
  
  /* Severity colors */
  --severity-critical: #FF4757;
  --severity-high: #FFA502;
  --severity-medium: #FFD93D;
  --severity-low: #2ED573;
  --severity-info: #4ECDC4;
  
  /* Backgrounds */
  --bg-critical: rgba(255, 71, 87, 0.08);
  --bg-high: rgba(255, 165, 2, 0.08);
  --bg-medium: rgba(255, 217, 61, 0.08);
  --bg-low: rgba(46, 213, 115, 0.08);
  --bg-info: rgba(78, 205, 196, 0.08);
  
  /* Typography */
  --font-mono: 'JetBrains Mono', monospace;
  --font-display: 'Syne', sans-serif;
  --font-body: 'Inter', sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; scroll-padding-top: 100px; }
body {
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: var(--font-body);
  line-height: 1.6;
  min-height: 100vh;
  letter-spacing: -0.3px;
}

/* ══════════════════ SIDEBAR NAVIGATION ══════════════════ */
.sidebar {
  position: fixed;
  left: 0;
  top: 0;
  width: 260px;
  height: 100vh;
  background: var(--bg-secondary);
  border-right: 1px solid var(--border-primary);
  overflow-y: auto;
  z-index: 100;
  padding-bottom: 40px;
  display: flex;
  flex-direction: column;
}

.sidebar::-webkit-scrollbar {
  width: 6px;
}
.sidebar::-webkit-scrollbar-track {
  background: transparent;
}
.sidebar::-webkit-scrollbar-thumb {
  background: var(--border-secondary);
  border-radius: 3px;
}

.sidebar-header {
  padding: 28px 24px 24px;
  border-bottom: 1px solid var(--border-primary);
  margin-bottom: 12px;
}

.sidebar-brand {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 800;
  letter-spacing: -1px;
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 4px;
}

.sidebar-subtitle {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.nav-section {
  padding: 16px 24px 8px;
  margin-top: 12px;
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 700;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  border-top: 1px solid var(--border-primary);
}

.nav-section:first-of-type { margin-top: 0; border-top: none; }

.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 11px 24px;
  font-size: 12px;
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  border-left: 3px solid transparent;
  position: relative;
}

.nav-item:hover {
  color: var(--accent-primary);
  background: rgba(0, 217, 255, 0.05);
  border-left-color: var(--accent-primary);
}

.nav-item.active {
  color: var(--accent-primary);
  background: rgba(0, 217, 255, 0.1);
  border-left-color: var(--accent-primary);
  font-weight: 600;
}

.nav-badge {
  margin-left: auto;
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 3px;
  min-width: 28px;
  text-align: center;
}

.badge-critical { background: var(--bg-critical); color: var(--severity-critical); }
.badge-high { background: var(--bg-high); color: var(--severity-high); }
.badge-medium { background: var(--bg-medium); color: var(--severity-medium); }
.badge-low { background: var(--bg-low); color: var(--severity-low); }
.badge-info { background: var(--bg-info); color: var(--severity-info); }

/* ══════════════════ HEADER/TOPBAR ══════════════════ */
.header {
  position: sticky;
  top: 0;
  left: 260px;
  right: 0;
  height: 80px;
  background: rgba(10, 14, 26, 0.8);
  backdrop-filter: blur(12px);
  border-bottom: 1pt solid var(--border-primary);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  z-index: 50;
}

.header-title {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5px;
}

.header-actions {
  display: flex;
  gap: 16px;
  align-items: center;
}

.btn-primary {
  padding: 8px 18px;
  border-radius: 6px;
  border: 1px solid var(--border-secondary);
  background: rgba(0, 217, 255, 0.08);
  color: var(--accent-primary);
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.btn-primary:hover {
  background: rgba(0, 217, 255, 0.15);
  border-color: var(--accent-primary);
  transform: translateY(-1px);
}

/* ══════════════════ MAIN CONTENT ══════════════════ */
.main {
  margin-left: 260px;
  min-height: 100vh;
  padding: 40px;
  padding-top: 120px;
}

/* ══════════════════ COVER PAGE ══════════════════ */
.cover-section {
  min-height: 80vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-bottom: 80px;
}

.cover-tag {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--accent-primary);
  text-transform: uppercase;
  letter-spacing: 0.13em;
  margin-bottom: 20px;
  font-weight: 700;
}

.cover-title {
  font-family: var(--font-display);
  font-size: 52px;
  font-weight: 800;
  letter-spacing: -2px;
  line-height: 1.1;
  color: var(--text-primary);
  margin-bottom: 12px;
}

.cover-subtitle {
  font-size: 17px;
  color: var(--text-secondary);
  font-weight: 300;
  margin-bottom: 48px;
  max-width: 600px;
}

.cover-meta-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  max-width: 900px;
  margin-bottom: 48px;
}

.cover-meta-item {
  background: var(--bg-tertiary);
  border: 1px solid var(--border-primary);
  border-radius: 8px;
  padding: 18px 20px;
  transition: all 0.2s;
}

.cover-meta-item:hover {
  border-color: var(--accent-primary);
  background: rgba(0, 217, 255, 0.04);
}

.cover-meta-label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 6px;
  font-weight: 700;
}

.cover-meta-value {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.risk-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 12px 28px;
  border-radius: 8px;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 16px;
  border: 2px solid;
  letter-spacing: -0.5px;
  margin-bottom: 8px;
}

.risk-Critical { background: var(--bg-critical); color: var(--severity-critical); border-color: var(--severity-critical); }
.risk-High { background: var(--bg-high); color: var(--severity-high); border-color: var(--severity-high); }
.risk-Medium { background: var(--bg-medium); color: var(--severity-medium); border-color: var(--severity-medium); }
.risk-Low { background: var(--bg-low); color: var(--severity-low); border-color: var(--severity-low); }
.risk-Clean { background: var(--bg-low); color: var(--severity-low); border-color: var(--severity-low); }

.risk-label {
  font-size: 10px;
  color: var(--text-tertiary);
  font-family: var(--font-mono);
  margin-bottom: 8px;
}

/* ══════════════════ SECTION HEADERS ══════════════════ */
.section {
  margin-bottom: 80px;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 36px;
  padding-bottom: 20px;
  border-bottom: 2px solid var(--border-secondary);
}

.section-number {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 800;
  color: var(--accent-primary);
  background: rgba(0, 217, 255, 0.1);
  border: 1px solid var(--border-primary);
  padding: 4px 10px;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.section-title {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -1px;
}

/* ══════════════════ STATISTICS GRID ══════════════════ */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 12px;
  margin-bottom: 40px;
}

.stat-card {
  background: var(--bg-tertiary);
  border: 1px solid var(--border-primary);
  border-radius: 8px;
  padding: 24px 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: all 0.3s;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--accent-primary);
}

.stat-card:hover {
  border-color: var(--accent-primary);
  background: rgba(0, 217, 255, 0.04);
  transform: translateY(-2px);
}

.stat-card.critical::before { background: var(--severity-critical); }
.stat-card.high::before { background: var(--severity-high); }
.stat-card.medium::before { background: var(--severity-medium); }
.stat-card.low::before { background: var(--severity-low); }
.stat-card.info::before { background: var(--severity-info); }

.stat-number {
  font-family: var(--font-mono);
  font-size: 36px;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 6px;
  color: var(--accent-primary);
}

.stat-card.critical .stat-number { color: var(--severity-critical); }
.stat-card.high .stat-number { color: var(--severity-high); }
.stat-card.medium .stat-number { color: var(--severity-medium); }
.stat-card.low .stat-number { color: var(--severity-low); }
.stat-card.info .stat-number { color: var(--severity-info); }

.stat-label {
  font-size: 11px;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-weight: 700;
}

/* ══════════════════ CHARTS ══════════════════ */
.charts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
  gap: 20px;
  margin-bottom: 40px;
}

.chart-card {
  background: var(--bg-tertiary);
  border: 1px solid var(--border-primary);
  border-radius: 10px;
  padding: 28px;
  transition: all 0.2s;
}

.chart-card:hover {
  border-color: var(--border-secondary);
}

.chart-card.full {
  grid-column: 1 / -1;
}

.chart-title {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 700;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.chart-container {
  position: relative;
  height: 280px;
}

/* ══════════════════ FINDING CARDS ══════════════════ */
.finding-card {
  background: var(--bg-tertiary);
  border: 1px solid var(--border-primary);
  border-radius: 10px;
  margin-bottom: 16px;
  overflow: hidden;
  transition: all 0.2s;
}

.finding-card:hover {
  border-color: var(--accent-primary);
  background: rgba(0, 217, 255, 0.02);
}

.card-header {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 24px;
  border-bottom: 1px solid var(--border-primary);
}

.card-body {
  padding: 24px;
}

.finding-title {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  flex: 1;
}

.finding-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 12px;
  align-items: center;
}

.badge {
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  border: 1px solid;
}

.badge-critical { background: var(--bg-critical); color: var(--severity-critical); border-color: rgba(255, 71, 87, 0.3); }
.badge-high { background: var(--bg-high); color: var(--severity-high); border-color: rgba(255, 165, 2, 0.3); }
.badge-medium { background: var(--bg-medium); color: var(--severity-medium); border-color: rgba(255, 217, 61, 0.3); }
.badge-low { background: var(--bg-low); color: var(--severity-low); border-color: rgba(46, 213, 115, 0.3); }
.badge-info { background: var(--bg-info); color: var(--severity-info); border-color: rgba(78, 205, 196, 0.3); }

.tag {
  font-family: var(--font-mono);
  font-size: 10px;
  padding: 3px 9px;
  background: var(--bg-hover);
  border: 1px solid var(--border-primary);
  border-radius: 4px;
  color: var(--text-secondary);
}

.tag.host {
  color: var(--accent-primary);
  border-color: rgba(0, 217, 255, 0.2);
}

/* ══════════════════ SECTION CONTENT ══════════════════ */
.content-section {
  margin-bottom: 20px;
}

.section-label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 8px;
  font-weight: 700;
}

.section-text {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.8;
}

.code-block {
  background: #050810;
  border: 1px solid var(--border-primary);
  border-radius: 6px;
  padding: 16px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: #00FF9F;
  white-space: pre-wrap;
  word-break: break-all;
  max-height: 280px;
  overflow-y: auto;
  line-height: 1.6;
  margin-top: 8px;
}

/* ══════════════════ TABLES ══════════════════ */
.table-wrapper {
  overflow-x: auto;
  border-radius: 8px;
  border: 1px solid var(--border-primary);
  margin-top: 12px;
}

table {
  width: 100%;
  border-collapse: collapse;
}

th {
  padding: 12px 14px;
  text-align: left;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border-primary);
}

td {
  padding: 12px 14px;
  font-size: 12px;
  color: var(--text-secondary);
  border-bottom: 1px solid var(--border-primary);
  vertical-align: middle;
}

tr:hover td {
  background: rgba(0, 217, 255, 0.02);
}

/* ══════════════════ FILTER BAR ══════════════════ */
.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
  align-items: center;
}

.filter-btn {
  padding: 6px 14px;
  border-radius: 6px;
  border: 1px solid var(--border-primary);
  background: transparent;
  color: var(--text-secondary);
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.filter-btn:hover {
  border-color: var(--accent-primary);
  color: var(--accent-primary);
}

.filter-btn.active {
  border-color: var(--accent-primary);
  color: var(--accent-primary);
  background: rgba(0, 217, 255, 0.1);
}

/* ══════════════════ RESPONSIVE ══════════════════ */
@media (max-width: 1200px) {
  .charts-grid {
    grid-template-columns: 1fr;
  }
  .cover-meta-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .sidebar {
    width: 220px;
  }
  .main {
    margin-left: 220px;
  }
  .header {
    left: 220px;
    padding: 0 24px;
  }
  .cover-meta-grid {
    grid-template-columns: 1fr;
  }
  .stats-grid {
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
  }
}

/* ══════════════════ PRINT STYLES ══════════════════ */
@media print {
  .sidebar, .header { display: none !important; }
  .main { margin-left: 0; }
  body { background: white; color: black; }
  .section { page-break-inside: avoid; }
  .finding-card { page-break-inside: avoid; }
}

/* ══════════════════ UTILITY CLASSES ══════════════════ */
.hidden { display: none !important; }
.text-center { text-align: center; }
.mt-4 { margin-top: 32px; }
.mb-4 { margin-bottom: 32px; }
.p-4 { padding: 32px; }
</style>
</head>
<body>

<!-- ════════════════ SIDEBAR ════════════════ -->
<nav class="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-brand">◈ RECON-X</div>
    <div class="sidebar-subtitle">v{{ tool_version }} · {{ profile|upper }} Profile</div>
  </div>
  
  <div class="nav-section">Overview</div>
  <a href="#cover" class="nav-item">◉ Cover</a>
  <a href="#executive" class="nav-item">◈ Executive Summary</a>
  <a href="#dashboard" class="nav-item">▦ Dashboard</a>
  
  <div class="nav-section">Targets & Findings</div>
  <a href="#targets" class="nav-item">▨ Targets</a>
  <a href="#findings-table" class="nav-item">
    ▤ Findings Table
    <span class="nav-badge badge-critical">{{ total_findings }}</span>
  </a>
  <a href="#findings-detail" class="nav-item">◎ Detailed Findings</a>
  
  <div class="nav-section">Security Data</div>
  <a href="#ports" class="nav-item">◈ Port Summary</a>
  <a href="#headers" class="nav-item">⚙ HTTP Headers</a>
  <a href="#certificates" class="nav-item">⊞ Certificates</a>
  <a href="#screenshots" class="nav-item">⊡ Screenshots</a>
  
  <div class="nav-section">More</div>
  <a href="#appendix" class="nav-item">≡ Appendix</a>
</nav>

<!-- ════════════════ HEADER ════════════════ -->
<header class="header">
  <div class="header-title">{{ title }}</div>
  <div class="header-actions">
    <button class="btn-primary" onclick="window.print()">⎙ Export PDF</button>
  </div>
</header>

<!-- ════════════════ MAIN CONTENT ════════════════ -->
<main class="main">

<!-- ════ 1. COVER ════ -->
<section id="cover" class="section cover-section">
  <div class="cover-tag">Security Reconnaissance Report</div>
  <h1 class="cover-title">{{ title }}</h1>
  <p class="cover-subtitle">Automated Network Security Assessment using RECON-X</p>
  
  <div class="cover-meta-grid">
    <div class="cover-meta-item">
      <div class="cover-meta-label">Report Date</div>
      <div class="cover-meta-value">{{ started_at }}</div>
    </div>
    <div class="cover-meta-item">
      <div class="cover-meta-label">Duration</div>
      <div class="cover-meta-value">{{ duration }}</div>
    </div>
    <div class="cover-meta-item">
      <div class="cover-meta-label">Targets</div>
      <div class="cover-meta-value">{{ total_targets }} ({{ alive_targets }} live)</div>
    </div>
    <div class="cover-meta-item">
      <div class="cover-meta-label">Profile</div>
      <div class="cover-meta-value">{{ profile|upper }}</div>
    </div>
  </div>
  
  <div>
    <div class="risk-label">Overall Risk Assessment</div>
    <div class="risk-badge risk-{{ overall_risk }}">⬤ {{ overall_risk|upper }}</div>
  </div>
</section>

<!-- ════ 2. EXECUTIVE SUMMARY ════ -->
<section id="executive" class="section">
  <div class="section-header">
    <span class="section-number">01</span>
    <h2 class="section-title">Executive Summary</h2>
  </div>
  
  <p class="section-text" style="margin-bottom: 28px; max-width: 900px;">
    This report documents a comprehensive security reconnaissance scan of <strong>{{ title }}</strong> conducted on <strong>{{ started_at }}</strong> using the RECON-X automated assessment framework with the <strong>{{ profile }}</strong> profile. The assessment covered <strong>{{ total_targets }}</strong> targets, of which <strong>{{ alive_targets }}</strong> were responsive. A total of <strong>{{ total_findings }}</strong> security findings were identified, categorized as follows:
  </p>
  
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-number">{{ total_findings }}</div>
      <div class="stat-label">Total Findings</div>
    </div>
    {% if severity_counts.Critical %}
    <div class="stat-card critical">
      <div class="stat-number">{{ severity_counts.Critical }}</div>
      <div class="stat-label">Critical</div>
    </div>
    {% endif %}
    {% if severity_counts.High %}
    <div class="stat-card high">
      <div class="stat-number">{{ severity_counts.High }}</div>
      <div class="stat-label">High</div>
    </div>
    {% endif %}
    {% if severity_counts.Medium %}
    <div class="stat-card medium">
      <div class="stat-number">{{ severity_counts.Medium }}</div>
      <div class="stat-label">Medium</div>
    </div>
    {% endif %}
    {% if severity_counts.Low %}
    <div class="stat-card low">
      <div class="stat-number">{{ severity_counts.Low }}</div>
      <div class="stat-label">Low</div>
    </div>
    {% endif %}
  </div>
  
  {% if top_findings %}
  <div class="mt-4">
    <div class="section-label">Top 5 Critical Findings</div>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th style="width: 5%">#</th>
            <th style="width: 15%">Severity</th>
            <th style="width: 40%">Finding</th>
            <th style="width: 25%">Target</th>
            <th style="width: 15%">Category</th>
          </tr>
        </thead>
        <tbody>
          {% for f in top_findings %}
          <tr>
            <td>{{ loop.index }}</td>
            <td><span class="badge badge-{{ f.severity|lower }}">{{ f.severity }}</span></td>
            <td><strong>{{ f.title }}</strong></td>
            <td><code style="color: var(--accent-primary)">{{ f.target }}{% if f.port %}:{{ f.port }}{% endif %}</code></td>
            <td><span class="tag">{{ f.category }}</span></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}
</section>

<!-- ════ 3. DASHBOARD ════ -->
<section id="dashboard" class="section">
  <div class="section-header">
    <span class="section-number">02</span>
    <h2 class="section-title">Security Dashboard</h2>
  </div>
  
  <div class="charts-grid">
    <div class="chart-card">
      <div class="chart-title">▦ Findings by Severity</div>
      <div class="chart-container"><canvas id="chart-severity"></canvas></div>
    </div>
    <div class="chart-card">
      <div class="chart-title">▦ Findings by Category</div>
      <div class="chart-container"><canvas id="chart-category"></canvas></div>
    </div>
    <div class="chart-card full">
      <div class="chart-title">▦ Top Vulnerable Hosts</div>
      <div class="chart-container"><canvas id="chart-hosts"></canvas></div>
    </div>
  </div>
</section>

<!-- ════ 4. TARGET DETAILS ════ -->
<section id="targets" class="section">
  <div class="section-header">
    <span class="section-number">03</span>
    <h2 class="section-title">Target Details</h2>
  </div>
  
  {% for tr in target_results %}
  <div class="finding-card">
    <div class="card-header">
      <div>
        <div class="finding-title">{{ tr.target.display_name }}</div>
        <div class="finding-meta">
          <span class="tag">{{ tr.status }}</span>
          {% if tr.open_ports %}<span class="tag">{{ tr.open_ports|length }} ports</span>{% endif %}
          {% if tr.findings %}<span class="tag">{{ tr.findings|length }} findings</span>{% endif %}
        </div>
      </div>
    </div>
    {% if tr.open_ports or tr.findings %}
    <div class="card-body">
      {% if tr.open_ports %}
      <div class="content-section">
        <div class="section-label">Open Ports</div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr><th>Port</th><th>Protocol</th><th>Service</th><th>Version</th><th>State</th></tr>
            </thead>
            <tbody>
              {% for port in tr.open_ports[:20] %}
              <tr>
                <td><code style="color: var(--accent-primary)">{{ port.port_number }}</code></td>
                <td>{{ port.protocol }}</td>
                <td>{{ port.service_name or '—' }}</td>
                <td style="font-size: 11px; color: var(--text-tertiary);">{{ port.service_version or '—' }}</td>
                <td>{{ port.state }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endif %}
    </div>
    {% endif %}
  </div>
  {% endfor %}
</section>

<!-- ════ 5. FINDINGS TABLE ════ -->
<section id="findings-table" class="section">
  <div class="section-header">
    <span class="section-number">04</span>
    <h2 class="section-title">Findings Table</h2>
  </div>
  
  <div class="filter-bar">
    <button class="filter-btn active" onclick="filterFindings('all')">All ({{ total_findings }})</button>
    {% if severity_counts.Critical %}<button class="filter-btn" onclick="filterFindings('Critical')">Critical ({{ severity_counts.Critical }})</button>{% endif %}
    {% if severity_counts.High %}<button class="filter-btn" onclick="filterFindings('High')">High ({{ severity_counts.High }})</button>{% endif %}
    {% if severity_counts.Medium %}<button class="filter-btn" onclick="filterFindings('Medium')">Medium ({{ severity_counts.Medium }})</button>{% endif %}
    {% if severity_counts.Low %}<button class="filter-btn" onclick="filterFindings('Low')">Low ({{ severity_counts.Low }})</button>{% endif %}
  </div>
  
  <div class="table-wrapper">
    <table id="findings-table-el">
      <thead>
        <tr>
          <th style="width: 5%">#</th>
          <th style="width: 12%">Severity</th>
          <th style="width: 35%">Finding</th>
          <th style="width: 22%">Target</th>
          <th style="width: 15%">Category</th>
          <th style="width: 11%">CVE</th>
        </tr>
      </thead>
      <tbody>
        {% for f in all_findings %}
        <tr class="finding-row" data-severity="{{ f.severity }}" onclick="document.getElementById('finding-{{ f.id }}').scrollIntoView({ behavior: 'smooth', block: 'start' });">
          <td>{{ loop.index }}</td>
          <td><span class="badge badge-{{ f.severity|lower }}">{{ f.severity[:4]|upper }}</span></td>
          <td><strong style="color: var(--accent-primary); cursor: pointer; text-decoration: underline;">{{ f.title }}</strong></td>
          <td><code>{{ f.target }}{% if f.port %}:{{ f.port }}{% endif %}</code></td>
          <td><span class="tag">{{ f.category }}</span></td>
          <td>{% if f.cve_ids %}{{ f.cve_ids[0] }}{% else %}—{% endif %}</td>
        </tr>
        {% else %}
        <tr><td colspan="6" style="text-align: center; color: var(--text-tertiary);">No findings recorded.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<!-- ════ 6. DETAILED FINDINGS ════ -->
<section id="findings-detail" class="section">
  <div class="section-header">
    <span class="section-number">05</span>
    <h2 class="section-title">Detailed Findings</h2>
  </div>
  
  {% for sev in severity_order %}
    {% set sev_findings = all_findings | selectattr('severity', 'eq', sev) | list %}
    {% if sev_findings %}
    <div style="margin-bottom: 40px;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
        <span class="badge badge-{{ sev|lower }}">{{ sev }}</span>
        <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary); font-weight: 600;">{{ sev_findings|length }} finding{{ 's' if sev_findings|length != 1 else '' }}</span>
      </div>
      
      {% for f in sev_findings %}
      <div class="finding-card" id="finding-{{ f.id }}">
        <div class="card-header">
          <span class="badge badge-{{ f.severity|lower }}">{{ f.severity }}</span>
          <div style="flex: 1; margin-left: 16px;">
            <div class="finding-title">{{ f.title }}</div>
            <div class="finding-meta">
              <span class="tag host">{{ f.target }}{% if f.port %}:{{ f.port }}{% endif %}</span>
              <span class="tag">{{ f.category }}</span>
              {% if f.cvss_score %}<span class="tag" style="color: var(--severity-{{ f.severity|lower }});">CVSS {{ f.cvss_score }}</span>{% endif %}
              {% for cve in f.cve_ids %}<a href="https://nvd.nist.gov/vuln/detail/{{ cve }}" target="_blank" style="text-decoration: none;"><span class="tag" style="color: var(--severity-critical); cursor: pointer;">{{ cve }}</span></a>{% endfor %}
            </div>
          </div>
        </div>
        <div class="card-body">
          {% if f.description %}
          <div class="content-section">
            <div class="section-label">Description</div>
            <div class="section-text">{{ f.description }}</div>
          </div>
          {% endif %}
          
          {% if f.evidence %}
          <div class="content-section">
            <div class="section-label">Evidence</div>
            <div class="code-block">{{ f.evidence }}</div>
          </div>
          {% endif %}
          
          {% if f.remediation %}
          <div class="content-section">
            <div class="section-label">Remediation</div>
            <div class="section-text">{{ f.remediation|replace('\n', '<br>') }}</div>
          </div>
          {% endif %}
          
          {% if f.references %}
          <div class="content-section">
            <div class="section-label">References</div>
            <ul style="margin-left: 20px;">
              {% for ref in f.references %}<li style="margin-bottom: 6px;"><a href="{{ ref }}" target="_blank" style="color: var(--accent-primary); text-decoration: none;">{{ ref }}</a></li>{% endfor %}
            </ul>
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  {% endfor %}
</section>

<!-- ════ 7. PORTS ════ -->
<section id="ports" class="section">
  <div class="section-header">
    <span class="section-number">06</span>
    <h2 class="section-title">Port Summary</h2>
  </div>
  {% if port_data %}
  {% for host in port_data %}
  <div class="finding-card" style="margin-bottom: 18px;">
    <div class="card-header">
      <div class="finding-title">{{ host.host }}</div>
      <div class="finding-meta"><span class="tag">{{ host.ports|length }} ports</span></div>
    </div>
    <div class="card-body">
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Port</th><th>Proto</th><th>Service</th><th>Version</th><th>Banner</th>
            </tr>
          </thead>
          <tbody>
            {% for p in host.ports %}
            <tr>
              <td><code style="color: var(--accent-primary)">{{ p.port }}</code></td>
              <td>{{ p.proto }}</td>
              <td>{{ p.service or '—' }}</td>
              <td style="font-size: 11px;">{{ p.version or '—' }}</td>
              <td style="font-size: 11px; color: var(--text-tertiary);">{{ p.banner or '—' }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  {% endfor %}
  {% else %}
  <p class="section-text">No open ports were captured in this scan.</p>
  {% endif %}
</section>

<!-- ════ 8. HTTP HEADERS ════ -->
<section id="headers" class="section">
  <div class="section-header">
    <span class="section-number">07</span>
    <h2 class="section-title">HTTP Security Headers</h2>
  </div>
  {% if headers_summary.total_security_issues or headers_summary.total_info_disclosure %}
  <div class="stats-grid">
    <div class="stat-card high">
      <div class="stat-number">{{ headers_summary.total_security_issues }}</div>
      <div class="stat-label">Security Header Issues</div>
    </div>
    <div class="stat-card medium">
      <div class="stat-number">{{ headers_summary.total_info_disclosure }}</div>
      <div class="stat-label">Info Disclosure Headers</div>
    </div>
  </div>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Type</th><th>Header</th><th>Severity</th><th>Target</th>
        </tr>
      </thead>
      <tbody>
        {% for h in headers_summary.security_headers.missing %}
        <tr><td>Missing</td><td>{{ h.header }}</td><td>{{ h.severity }}</td><td>{{ h.target }}</td></tr>
        {% endfor %}
        {% for h in headers_summary.security_headers.wrongly_configured %}
        <tr><td>Misconfigured</td><td>{{ h.header }}</td><td>{{ h.severity }}</td><td>{{ h.target }}</td></tr>
        {% endfor %}
        {% for h in headers_summary.info_disclosure_headers.present %}
        <tr><td>Info Disclosure</td><td>{{ h.header }}</td><td>{{ h.severity }}</td><td>{{ h.target }}</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <p class="section-text">No HTTP header findings were identified.</p>
  {% endif %}
</section>

<!-- ════ 9. CERTIFICATES ════ -->
<section id="certificates" class="section">
  <div class="section-header">
    <span class="section-number">08</span>
    <h2 class="section-title">TLS/SSL Certificates</h2>
  </div>
  {% if cert_data %}
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Host</th><th>Port</th><th>CN</th><th>Issuer</th><th>Expiry</th><th>Days Left</th><th>Flags</th>
        </tr>
      </thead>
      <tbody>
        {% for c in cert_data %}
        <tr>
          <td>{{ c.host }}</td>
          <td>{{ c.port }}</td>
          <td>{{ c.cn or '—' }}</td>
          <td>{{ c.issuer or '—' }}</td>
          <td>{{ c.expiry or '—' }}</td>
          <td>{{ c.days_left if c.days_left is not none else '—' }}</td>
          <td>
            {% if c.self_signed %}<span class="tag">Self-signed</span>{% endif %}
            {% if c.expired %}<span class="tag" style="color: var(--severity-critical)">Expired</span>{% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <p class="section-text">No certificate data was collected.</p>
  {% endif %}
</section>

<!-- ════ 10. SCREENSHOTS ════ -->
<section id="screenshots" class="section" style="margin-bottom: 40px;">
  <div class="section-header">
    <span class="section-number">09</span>
    <h2 class="section-title">Web Screenshots</h2>
  </div>
  {% if screenshots %}
  <div class="charts-grid" style="grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));">
    {% for s in screenshots %}
    <div class="finding-card">
      <div class="card-header">
        <div>
          <div class="finding-title">{{ s.host }}:{{ s.port }}</div>
          <div class="finding-meta">
            <span class="tag">{{ s.scheme|upper }}</span>
            {% if s.status_code %}<span class="tag">HTTP {{ s.status_code }}</span>{% endif %}
          </div>
        </div>
      </div>
      <div class="card-body">
        {% if s.encoded_image %}
        <img src="{{ s.encoded_image }}" alt="{{ s.final_url }}" style="width: 100%; border-radius: 8px; border: 1px solid var(--border-primary);"/>
        {% else %}
        <p class="section-text">Screenshot not available{% if s.error %}: {{ s.error }}{% endif %}</p>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <p class="section-text">No screenshots were captured for this scan.</p>
  {% endif %}
</section>

<!-- ════ 11. APPENDIX ════ -->
<section id="appendix" class="section" style="margin-bottom: 120px;">
  <div class="section-header">
    <span class="section-number">10</span>
    <h2 class="section-title">Appendix</h2>
  </div>
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-number">{{ total_targets }}</div>
      <div class="stat-label">Total Targets</div>
    </div>
    <div class="stat-card">
      <div class="stat-number">{{ alive_targets }}</div>
      <div class="stat-label">Alive Targets</div>
    </div>
    <div class="stat-card">
      <div class="stat-number">{{ total_findings }}</div>
      <div class="stat-label">Total Findings</div>
    </div>
  </div>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Host</th><th>IP</th><th>Status</th><th>Duration</th><th>Open Ports</th><th>Findings</th>
        </tr>
      </thead>
      <tbody>
        {% for t in target_statuses %}
        <tr>
          <td>{{ t.host }}</td>
          <td>{{ t.ip or '—' }}</td>
          <td>{{ t.status }}</td>
          <td>{{ t.duration }}</td>
          <td>{{ t.open_ports }}</td>
          <td>{{ t.findings }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <p class="section-text" style="margin-top: 16px;">
    Scan started: {{ started_at }} · Scan finished: {{ finished_at }} · Total duration: {{ duration }} · Generated: {{ generated_at }}
  </p>
</section>

</main>

<script>
const severityCounts = {{ severity_counts | tojson }};
const categoryCounts = {{ category_counts | tojson }};
const topHosts = {{ top_hosts | tojson }};

const severityLabels = ['Critical', 'High', 'Medium', 'Low', 'Informational'];
const severityColors = ['#FF4757', '#FFA502', '#FFD93D', '#2ED573', '#4ECDC4'];
const severityValues = severityLabels.map((k) => severityCounts[k] || 0);

const chartDefaults = {
  color: '#B4BAC4',
  borderColor: '#1F2A3D',
};

Chart.defaults.color = chartDefaults.color;
Chart.defaults.borderColor = chartDefaults.borderColor;

new Chart(document.getElementById('chart-severity'), {
  type: 'doughnut',
  data: {
    labels: severityLabels,
    datasets: [{ data: severityValues, backgroundColor: severityColors, borderWidth: 1 }],
  },
  options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } },
});

new Chart(document.getElementById('chart-category'), {
  type: 'bar',
  data: {
    labels: Object.keys(categoryCounts),
    datasets: [{
      label: 'Findings',
      data: Object.values(categoryCounts),
      backgroundColor: '#00D9FF',
    }],
  },
  options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } },
});

new Chart(document.getElementById('chart-hosts'), {
  type: 'bar',
  data: {
    labels: topHosts.map((h) => h.host),
    datasets: [{ label: 'Findings', data: topHosts.map((h) => h.finding_count), backgroundColor: '#A78BFA' }],
  },
  options: {
    indexAxis: 'y',
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false } },
  },
});

function filterFindings(severity) {
  const btn = event.target;
  document.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
  btn.classList.add('active');
  const rows = document.querySelectorAll('.finding-row');
  rows.forEach((row) => {
    row.style.display = (severity === 'all' || row.dataset.severity === severity) ? '' : 'none';
  });
}
</script>

</body>
</html>
