<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>RECON-X | {{ title }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root {
  --bg: #070B14;
  --bg2: #0D1424;
  --card: #111827;
  --card2: #1a2236;
  --border: #1E2D45;
  --border2: #253450;
  --accent: #3B82F6;
  --accent2: #60A5FA;
  --text: #E2E8F0;
  --text2: #94A3B8;
  --text3: #64748B;
  --crit: #EF4444;
  --high: #F97316;
  --med: #EAB308;
  --low: #22C55E;
  --info: #6B7280;
  --crit-bg: rgba(239,68,68,0.12);
  --high-bg: rgba(249,115,22,0.12);
  --med-bg: rgba(234,179,8,0.12);
  --low-bg: rgba(34,197,94,0.12);
  --info-bg: rgba(107,114,128,0.12);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;scroll-padding-top:80px;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;line-height:1.6;min-height:100vh;overflow-x:hidden;}

/* ── Sidebar ── */
.layout{display:flex;min-height:100vh;}
.sidebar{width:240px;background:var(--bg2);border-right:1px solid var(--border);position:fixed;top:0;left:0;bottom:0;overflow-y:auto;z-index:100;padding:0 0 40px;}
.sidebar-logo{padding:24px 20px 16px;border-bottom:1px solid var(--border);margin-bottom:8px;}
.sidebar-logo .brand{font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:15px;color:var(--accent2);letter-spacing:0.05em;}
.sidebar-logo .sub{font-size:11px;color:var(--text3);margin-top:2px;font-family:'IBM Plex Mono',monospace;}
.nav-section{padding:12px 20px 6px;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--text3);font-family:'IBM Plex Mono',monospace;margin-top:8px;}
.nav-section:first-of-type{margin-top:0;}
.nav-item{display:flex;align-items:center;gap:8px;padding:9px 20px;font-size:13px;color:var(--text2);text-decoration:none;transition:all 0.2s cubic-bezier(0.4,0,0.2,1);border-left:3px solid transparent;position:relative;}
.nav-item:hover{color:var(--text);background:rgba(59,130,246,0.08);border-left-color:var(--accent);}
.nav-item.active{color:var(--accent2);background:rgba(59,130,246,0.12);border-left-color:var(--accent);font-weight:500;}
.nav-item .badge{margin-left:auto;font-family:'IBM Plex Mono',monospace;font-size:10px;padding:2px 7px;border-radius:4px;font-weight:600;min-width:24px;text-align:center;}
.badge-crit{background:var(--crit-bg);color:var(--crit);}
.badge-high{background:var(--high-bg);color:var(--high);}
.badge-med{background:var(--med-bg);color:var(--med);}
.badge-low{background:var(--low-bg);color:var(--low);}
.badge-info{background:var(--info-bg);color:var(--info);}

/* ── Main Content ── */
.main{margin-left:240px;flex:1;min-width:0;}
.topbar{position:sticky;top:0;background:rgba(7,11,20,0.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:12px 32px;display:flex;align-items:center;justify-content:space-between;z-index:50;}
.topbar-title{font-family:'IBM Plex Mono',monospace;font-size:13px;color:var(--text2);}
.topbar-title span{color:var(--text);font-weight:600;}
.print-btn{background:var(--card2);border:1px solid var(--border2);color:var(--text2);padding:6px 16px;border-radius:6px;font-size:12px;font-family:'IBM Plex Mono',monospace;cursor:pointer;transition:all 0.15s;letter-spacing:0.03em;}
.print-btn:hover{color:var(--text);border-color:var(--accent);}
.content{padding:40px 40px 80px;}

/* ── Sections ── */
section{margin-bottom:64px;}
.section-header{display:flex;align-items:center;gap:12px;margin-bottom:28px;padding-bottom:16px;border-bottom:1px solid var(--border);}
.section-number{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--accent);border:1px solid var(--accent);border-radius:4px;padding:2px 7px;letter-spacing:0.05em;}
.section-title{font-family:'Syne',sans-serif;font-size:22px;font-weight:700;color:var(--text);}

/* ── Cover Page ── */
.cover{min-height:80vh;display:flex;flex-direction:column;justify-content:center;padding:40px 0;position:relative;}
.cover-tag{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--accent);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:16px;}
.cover-title{font-family:'Syne',sans-serif;font-size:48px;font-weight:800;line-height:1.1;color:var(--text);margin-bottom:8px;}
.cover-subtitle{font-size:18px;color:var(--text2);margin-bottom:40px;font-weight:300;}
.cover-meta{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;max-width:500px;margin-bottom:40px;}
.cover-meta-item{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:16px;}
.cover-meta-label{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--text3);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:4px;}
.cover-meta-value{font-size:14px;font-weight:500;color:var(--text);}
.risk-badge{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:8px;font-family:'Syne',sans-serif;font-weight:700;font-size:18px;border:2px solid;}
.risk-Critical{background:var(--crit-bg);color:var(--crit);border-color:var(--crit);}
.risk-High{background:var(--high-bg);color:var(--high);border-color:var(--high);}
.risk-Medium{background:var(--med-bg);color:var(--med);border-color:var(--med);}
.risk-Low{background:var(--low-bg);color:var(--low);border-color:var(--low);}
.risk-Clean{background:var(--low-bg);color:var(--low);border-color:var(--low);}
.cover-deco{position:absolute;right:0;top:50%;transform:translateY(-50%);width:400px;height:400px;background:radial-gradient(ellipse at center, rgba(59,130,246,0.08) 0%, transparent 70%);border-radius:50%;pointer-events:none;}

/* ── Stats grid ── */
.stats-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:32px;}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:20px;text-align:center;position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.stat-Critical::before{background:var(--crit);}
.stat-High::before{background:var(--high);}
.stat-Medium::before{background:var(--med);}
.stat-Low::before{background:var(--low);}
.stat-Informational::before{background:var(--info);}
.stat-total::before{background:var(--accent);}
.stat-num{font-family:'IBM Plex Mono',monospace;font-size:32px;font-weight:600;line-height:1;margin-bottom:4px;}
.stat-label{font-size:12px;color:var(--text3);text-transform:uppercase;letter-spacing:0.06em;}
.stat-Critical .stat-num{color:var(--crit);}
.stat-High .stat-num{color:var(--high);}
.stat-Medium .stat-num{color:var(--med);}
.stat-Low .stat-num{color:var(--low);}
.stat-Informational .stat-num{color:var(--info);}
.stat-total .stat-num{color:var(--accent2);}

/* ── Charts ── */
.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:32px;}
.chart-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:24px;}
.chart-card-full{grid-column:1/-1;}
.chart-title{font-family:'IBM Plex Mono',monospace;font-size:13px;font-weight:500;color:var(--text2);margin-bottom:16px;letter-spacing:0.03em;}
.chart-wrap{position:relative;height:260px;}

/* ── Top-5 table ── */
.top5-table{width:100%;border-collapse:collapse;}
.top5-table th{text-align:left;padding:10px 14px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:0.06em;border-bottom:1px solid var(--border);}
.top5-table td{padding:12px 14px;font-size:13px;border-bottom:1px solid var(--border);vertical-align:middle;}
.top5-table tr:last-child td{border-bottom:none;}
.top5-table tr:hover td{background:var(--card2);}

/* ── Navigation Cards ── */
.nav-card{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;padding:20px;background:var(--card);border:1px solid var(--border);border-radius:10px;text-decoration:none;transition:all 0.2s cubic-bezier(0.4,0,0.2,1);color:var(--text);}
.nav-card:hover{background:rgba(59,130,246,0.08);border-color:var(--accent);transform:translateY(-2px);box-shadow:0 4px 12px rgba(59,130,246,0.1);}
.nav-card-icon{font-size:28px;color:var(--accent2);}
.nav-card-title{font-size:12px;font-weight:600;color:var(--text2);text-align:center;text-transform:uppercase;letter-spacing:0.04em;}
.nav-card-count{font-size:20px;font-weight:700;color:var(--accent2);font-family:'IBM Plex Mono',monospace;}

/* ── Severity pill ── */
.pill{display:inline-flex;align-items:center;padding:2px 10px;border-radius:20px;font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:600;letter-spacing:0.03em;border:1px solid;}
.pill-Critical{background:var(--crit-bg);color:var(--crit);border-color:rgba(239,68,68,0.3);}
.pill-High{background:var(--high-bg);color:var(--high);border-color:rgba(249,115,22,0.3);}
.pill-Medium{background:var(--med-bg);color:var(--med);border-color:rgba(234,179,8,0.3);}
.pill-Low{background:var(--low-bg);color:var(--low);border-color:rgba(34,197,94,0.3);}
.pill-Informational{background:var(--info-bg);color:var(--info);border-color:rgba(107,114,128,0.3);}

/* ── Findings filter bar ── */
.filter-bar{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;align-items:center;}
.filter-btn{background:var(--card);border:1px solid var(--border);color:var(--text2);padding:6px 14px;border-radius:6px;font-size:12px;font-family:'IBM Plex Mono',monospace;cursor:pointer;transition:all 0.15s;}
.filter-btn:hover,.filter-btn.active{border-color:var(--accent);color:var(--text);}
.filter-btn.active-crit{border-color:var(--crit);color:var(--crit);background:var(--crit-bg);}
.filter-btn.active-high{border-color:var(--high);color:var(--high);background:var(--high-bg);}
.filter-btn.active-med{border-color:var(--med);color:var(--med);background:var(--med-bg);}
.filter-btn.active-low{border-color:var(--low);color:var(--low);background:var(--low-bg);}
.filter-btn.active-info{border-color:var(--info);color:var(--info);background:var(--info-bg);}
.search-input{background:var(--card);border:1px solid var(--border);color:var(--text);padding:6px 14px;border-radius:6px;font-size:12px;font-family:'IBM Plex Mono',monospace;width:200px;outline:none;}
.search-input:focus{border-color:var(--accent);}
.cat-select{background:var(--card);border:1px solid var(--border);color:var(--text2);padding:6px 14px;border-radius:6px;font-size:12px;font-family:'IBM Plex Mono',monospace;cursor:pointer;outline:none;}

/* ── Findings table ── */
.findings-table-wrap{overflow-x:auto;border-radius:10px;border:1px solid var(--border);}
.findings-table{width:100%;border-collapse:collapse;}
.findings-table th{padding:10px 14px;text-align:left;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:0.06em;background:var(--bg2);border-bottom:1px solid var(--border);}
.findings-table td{padding:12px 14px;font-size:13px;border-bottom:1px solid var(--border);vertical-align:middle;}
.findings-table tr:last-child td{border-bottom:none;}
.findings-table tbody tr{cursor:pointer;transition:background 0.1s;}
.findings-table tbody tr:hover td{background:var(--card2);}
.findings-table .f-title{color:var(--text);font-weight:500;}
.findings-table .f-target{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--accent2);}
.findings-table .f-cve{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3);}

/* ── Finding cards ── */
.finding-card{background:var(--card);border:1px solid var(--border);border-radius:10px;margin-bottom:16px;overflow:hidden;transition:border-color 0.2s;}
.finding-card:hover{border-color:var(--border2);}
.finding-card-header{display:flex;align-items:flex-start;gap:14px;padding:20px 24px;border-bottom:1px solid var(--border);}
.finding-card-body{padding:20px 24px;}
.finding-card-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:600;color:var(--text);flex:1;line-height:1.3;}
.finding-card-meta{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;align-items:center;}
.meta-tag{font-family:'IBM Plex Mono',monospace;font-size:11px;padding:2px 8px;background:var(--bg2);border:1px solid var(--border);border-radius:4px;color:var(--text2);}
.meta-tag.host-tag{color:var(--accent2);}
.finding-section{margin-bottom:16px;}
.finding-section-label{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:6px;}
.finding-section-text{font-size:13px;color:var(--text2);line-height:1.6;}
.evidence-block{background:#050810;border:1px solid var(--border);border-radius:6px;padding:14px 16px;font-family:'IBM Plex Mono',monospace;font-size:12px;color:#7DD3FC;white-space:pre-wrap;word-break:break-all;max-height:300px;overflow-y:auto;line-height:1.5;}
.cve-link{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--crit);text-decoration:none;border:1px solid rgba(239,68,68,0.3);border-radius:4px;padding:1px 7px;background:var(--crit-bg);}
.cve-link:hover{background:rgba(239,68,68,0.2);}
.ref-link{font-size:12px;color:var(--accent2);text-decoration:none;font-family:'IBM Plex Mono',monospace;}
.ref-link:hover{text-decoration:underline;}
.cvss-badge{font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:600;padding:3px 8px;border-radius:4px;border:1px solid;}
.cvss-Critical{background:var(--crit-bg);color:var(--crit);border-color:rgba(239,68,68,0.3);}
.cvss-High{background:var(--high-bg);color:var(--high);border-color:rgba(249,115,22,0.3);}
.cvss-Medium{background:var(--med-bg);color:var(--med);border-color:rgba(234,179,8,0.3);}
.cvss-Low{background:var(--low-bg);color:var(--low);border-color:rgba(34,197,94,0.3);}

/* ── Screenshots ── */
.screenshots-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;}
.screenshot-card{background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden;}
.screenshot-header{padding:14px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;}
.screenshot-host{font-family:'IBM Plex Mono',monospace;font-size:13px;color:var(--text);font-weight:500;}
.scheme-badge{font-family:'IBM Plex Mono',monospace;font-size:10px;font-weight:600;padding:2px 6px;border-radius:4px;}
.scheme-https{background:rgba(34,197,94,0.15);color:var(--low);border:1px solid rgba(34,197,94,0.3);}
.scheme-http{background:rgba(249,115,22,0.15);color:var(--high);border:1px solid rgba(249,115,22,0.3);}
.screenshot-meta{padding:10px 16px;font-size:12px;color:var(--text3);font-family:'IBM Plex Mono',monospace;border-bottom:1px solid var(--border);}
.screenshot-img-wrap{background:#000;min-height:180px;display:flex;align-items:center;justify-content:center;}
.screenshot-img{width:100%;height:auto;display:block;}
.screenshot-error{padding:40px;text-align:center;color:var(--text3);font-size:13px;}

/* ── Cert table ── */
.cert-table{width:100%;border-collapse:collapse;}
.cert-table th{padding:10px 14px;text-align:left;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:0.06em;background:var(--bg2);border-bottom:1px solid var(--border);}
.cert-table td{padding:12px 14px;font-size:13px;border-bottom:1px solid var(--border);font-family:'IBM Plex Mono',monospace;}
.cert-table tr:last-child td{border-bottom:none;}
.cert-expired{color:var(--crit);}
.cert-expiring{color:var(--high);}
.cert-expiring-soon{color:var(--med);}
.cert-ok{color:var(--low);}

/* ── Port accordion ── */
.port-accordion{margin-bottom:8px;background:var(--card);border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.port-accordion-header{padding:14px 20px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;font-family:'IBM Plex Mono',monospace;font-size:13px;color:var(--text);user-select:none;}
.port-accordion-header:hover{background:var(--card2);}
.port-accordion-body{display:none;padding:0 20px 16px;}
.port-accordion.open .port-accordion-body{display:block;}
.port-accordion-arrow{transition:transform 0.2s;color:var(--text3);}
.port-accordion.open .port-accordion-arrow{transform:rotate(90deg);}
.port-table{width:100%;border-collapse:collapse;margin-top:12px;}
.port-table th{padding:8px 12px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3);text-align:left;border-bottom:1px solid var(--border);}
.port-table td{padding:8px 12px;font-family:'IBM Plex Mono',monospace;font-size:12px;border-bottom:1px solid var(--border);color:var(--text2);}
.port-table tr:last-child td{border-bottom:none;}
.port-num{color:var(--accent2);}
.port-service{color:var(--text);}

/* ── Target status table ── */
.status-badge{font-family:'IBM Plex Mono',monospace;font-size:11px;padding:2px 8px;border-radius:4px;}
.status-completed{background:rgba(34,197,94,0.12);color:var(--low);}
.status-failed,.status-timeout{background:var(--crit-bg);color:var(--crit);}
.status-unreachable{background:var(--info-bg);color:var(--info);}
.status-scanning{background:rgba(59,130,246,0.12);color:var(--accent2);}

/* ── Misc ── */
.exec-paragraph{font-size:15px;color:var(--text2);line-height:1.8;margin-bottom:24px;max-width:800px;}
.no-results{padding:48px;text-align:center;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:13px;}
.table-wrap{border-radius:10px;border:1px solid var(--border);overflow:hidden;}
.hidden{display:none!important;}
a{color:inherit;}

@media print {
  .sidebar,.topbar,.print-btn,.filter-bar{display:none!important;}
  .main{margin-left:0;}
  body{background:#fff;color:#000;}
  .cover-page{page-break-after:always;}
  .finding-card{page-break-inside:avoid;}
}
</style>
</head>
<body>
<div class="layout">

<!-- ══ SIDEBAR ══════════════════════════════════════════════ -->
<nav class="sidebar">
  <div class="sidebar-logo">
    <div class="brand">◈ RECON-X</div>
    <div class="sub">v{{ tool_version }} — {{ profile|upper }} PROFILE</div>
  </div>
  <div class="nav-section">Report</div>
  <a href="#cover" class="nav-item">◉ Cover</a>
  <a href="#executive" class="nav-item">◈ Executive Summary</a>
  <a href="#dashboard" class="nav-item">▦ Dashboard</a>
  <a href="#target-details" class="nav-item">▨ Target Details</a>
  <div class="nav-section">Findings</div>
  <a href="#findings-table" class="nav-item">
    ▤ Findings Table
    <span class="badge badge-crit">{{ total_findings }}</span>
  </a>
  <a href="#findings-detail" class="nav-item">
    ◎ Detailed Findings
    {% if severity_counts.Critical %}<span class="badge badge-crit">{{ severity_counts.Critical }}C</span>{% endif %}
  </a>
  <div class="nav-section">Artifacts & Security</div>
  <a href="#headers" class="nav-item">
    ⚙ Headers Summary
    {% if headers_summary %}<span class="badge badge-med">{{ headers_summary.total_security_issues }}</span>{% endif %}
  </a>
  <a href="#screenshots" class="nav-item">⊡ Screenshots</a>
  <a href="#certificates" class="nav-item">⊞ Certificates</a>
  <a href="#ports" class="nav-item">◈ Port Summary</a>
  <div class="nav-section">Appendix</div>
  <a href="#appendix" class="nav-item">≡ Appendix</a>
</nav>

<!-- ══ MAIN ══════════════════════════════════════════════════ -->
<div class="main">
<div class="topbar">
  <div class="topbar-title">RECON-X / <span>{{ title }}</span></div>
  <button class="print-btn" onclick="window.print()">⎙ Export PDF</button>
</div>
<div class="content">

<!-- ════════════════════ 1. COVER PAGE ════════════════════ -->
<section id="cover" class="cover">
  <div class="cover-deco"></div>
  <div class="cover-tag">Security Reconnaissance Report</div>
  <div class="cover-title">{{ title }}</div>
  <div class="cover-subtitle">RECON-X Automated Security Assessment</div>
  <div class="cover-meta">
    <div class="cover-meta-item">
      <div class="cover-meta-label">Scan Date</div>
      <div class="cover-meta-value">{{ started_at }}</div>
    </div>
    <div class="cover-meta-item">
      <div class="cover-meta-label">Duration</div>
      <div class="cover-meta-value">{{ duration }}</div>
    </div>
    <div class="cover-meta-item">
      <div class="cover-meta-label">Targets Scanned</div>
      <div class="cover-meta-value">{{ total_targets }} ({{ alive_targets }} alive)</div>
    </div>
    <div class="cover-meta-item">
      <div class="cover-meta-label">Scan Profile</div>
      <div class="cover-meta-value">{{ profile|upper }}</div>
    </div>
  </div>
  <div style="margin-bottom:16px;font-size:13px;color:var(--text3);font-family:'IBM Plex Mono',monospace;">Overall Risk Rating</div>
  <div class="risk-badge risk-{{ overall_risk }}">⬤ {{ overall_risk|upper }}</div>
</section>

<!-- ════════════════════ 2. EXECUTIVE SUMMARY ════════════════ -->
<section id="executive">
  <div class="section-header">
    <span class="section-number">01</span>
    <span class="section-title">Executive Summary</span>
  </div>

  <p class="exec-paragraph">
    This report presents the findings from an automated security reconnaissance scan conducted on
    <strong>{{ started_at }}</strong> using RECON-X with the <strong>{{ profile }}</strong> scan profile.
    A total of <strong>{{ total_targets }} targets</strong> were scanned, of which
    <strong>{{ alive_targets }}</strong> were reachable and assessed.
    The scan identified <strong>{{ total_findings }} security findings</strong>:
    {% if severity_counts.Critical %}<span style="color:var(--crit)"><strong>{{ severity_counts.Critical }} Critical</strong></span>,{% endif %}
    {% if severity_counts.High %}<span style="color:var(--high)"><strong>{{ severity_counts.High }} High</strong></span>,{% endif %}
    {% if severity_counts.Medium %}<span style="color:var(--med)"><strong>{{ severity_counts.Medium }} Medium</strong></span>,{% endif %}
    {% if severity_counts.Low %}<span style="color:var(--low)"><strong>{{ severity_counts.Low }} Low</strong></span>, and{% endif %}
    <span style="color:var(--info)"><strong>{{ severity_counts.Informational }} Informational</strong></span>.
    The overall risk rating is assessed as <strong class="risk-{{ overall_risk }}" style="font-family:'IBM Plex Mono',monospace;">{{ overall_risk|upper }}</strong>
    with a computed risk score of <strong>{{ risk_score }}/100</strong>.
  </p>

  <!-- Stats -->
  <div class="stats-grid">
    <div class="stat-card stat-total">
      <div class="stat-num count-up" data-target="{{ total_findings }}">0</div>
      <div class="stat-label">Total Findings</div>
    </div>
    <div class="stat-card stat-Critical">
      <div class="stat-num count-up" data-target="{{ severity_counts.Critical }}">0</div>
      <div class="stat-label">Critical</div>
    </div>
    <div class="stat-card stat-High">
      <div class="stat-num count-up" data-target="{{ severity_counts.High }}">0</div>
      <div class="stat-label">High</div>
    </div>
    <div class="stat-card stat-Medium">
      <div class="stat-num count-up" data-target="{{ severity_counts.Medium }}">0</div>
      <div class="stat-label">Medium</div>
    </div>
    <div class="stat-card stat-Low">
      <div class="stat-num count-up" data-target="{{ severity_counts.Low }}">0</div>
      <div class="stat-label">Low</div>
    </div>
  </div>

  <!-- Top 5 Findings -->
  {% if top_findings %}
  <div style="margin-top:28px;">
    <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px;">Top Critical Findings</div>
    <div class="table-wrap">
      <table class="top5-table">
        <thead>
          <tr>
            <th>#</th><th>Severity</th><th>Title</th><th>Target</th><th>Category</th>
          </tr>
        </thead>
        <tbody>
          {% for f in top_findings %}
          <tr>
            <td style="font-family:'IBM Plex Mono',monospace;color:var(--text3);">{{ loop.index }}</td>
            <td><span class="pill pill-{{ f.severity }}">{{ f.severity }}</span></td>
            <td><a href="#finding-{{ f.id }}" style="color:var(--text);text-decoration:none;font-weight:500;">{{ f.title }}</a></td>
            <td style="font-family:'IBM Plex Mono',monospace;color:var(--accent2);font-size:12px;">{{ f.target }}{% if f.port %}:{{ f.port }}{% endif %}</td>
            <td><span class="meta-tag">{{ f.category }}</span></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}
</section>

<!-- ════════════════════ 3. DASHBOARD ════════════════════ -->
<section id="dashboard">
  <div class="section-header">
    <span class="section-number">02</span>
    <span class="section-title">Severity Dashboard</span>
  </div>

  <div class="charts-grid">
    <div class="chart-card">
      <div class="chart-title">▦ Findings by Severity</div>
      <div class="chart-wrap"><canvas id="chart-severity"></canvas></div>
    </div>
    <div class="chart-card">
      <div class="chart-title">▦ Findings by Category</div>
      <div class="chart-wrap"><canvas id="chart-category"></canvas></div>
    </div>
    <div class="chart-card chart-card-full">
      <div class="chart-title">▦ Top Vulnerable Hosts (Risk Score)</div>
      <div class="chart-wrap" style="height:300px;"><canvas id="chart-hosts"></canvas></div>
    </div>
  </div>

  <!-- Quick Navigation Cards -->
  <div style="margin-top:40px;padding-top:32px;border-top:1px solid var(--border);">
    <div style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:20px;text-transform:uppercase;letter-spacing:0.5px;">Quick Navigation</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;">
      <a href="#findings-table" class="nav-card">
        <div class="nav-card-icon">▤</div>
        <div class="nav-card-title">All Findings</div>
        <div class="nav-card-count">{{ total_findings }}</div>
      </a>
      {% if headers_summary and headers_summary.total_security_issues > 0 %}
      <a href="#headers" class="nav-card">
        <div class="nav-card-icon">⚙</div>
        <div class="nav-card-title">Headers Issues</div>
        <div class="nav-card-count">{{ headers_summary.total_security_issues }}</div>
      </a>
      {% endif %}
      {% if headers_summary and headers_summary.total_info_disclosure > 0 %}
      <a href="#headers" class="nav-card">
        <div class="nav-card-icon">ℹ</div>
        <div class="nav-card-title">Info Disclosure</div>
        <div class="nav-card-count">{{ headers_summary.total_info_disclosure }}</div>
      </a>
      {% endif %}
      <a href="#target-details" class="nav-card">
        <div class="nav-card-icon">▨</div>
        <div class="nav-card-title">Targets</div>
        <div class="nav-card-count">{{ total_targets }}</div>
      </a>
      <a href="#ports" class="nav-card">
        <div class="nav-card-icon">◈</div>
        <div class="nav-card-title">Ports</div>
        <div class="nav-card-count">{{ port_data|length }}</div>
      </a>
      <a href="#certificates" class="nav-card">
        <div class="nav-card-icon">⊞</div>
        <div class="nav-card-title">Certificates</div>
        <div class="nav-card-count">{{ cert_data|length }}</div>
      </a>
    </div>
  </div>
</section>

<!-- ════════════════════ 4. TARGET DETAILS ════════════════════ -->
<section id="target-details">
  <div class="section-header">
    <span class="section-number">03</span>
    <span class="section-title">Target Details</span>
  </div>

  {% for tr in target_results %}
  <div class="finding-card" style="margin-bottom:24px;">
    <div class="finding-card-header">
      <div class="finding-card-title">{{ tr.target.display_name }}</div>
      <div class="finding-card-meta">
        <span class="meta-tag host-tag">{{ tr.status }}</span>
        {% if tr.open_ports %}
        <span class="meta-tag">{{ tr.open_ports|length }} open port{{ 's' if tr.open_ports|length != 1 else '' }}</span>
        {% endif %}
        {% if tr.findings %}
        <span class="meta-tag">{{ tr.findings|length }} finding{{ 's' if tr.findings|length != 1 else '' }}</span>
        {% endif %}
      </div>
    </div>
    <div class="finding-card-body">
      {% if tr.open_ports %}
      <div class="finding-section">
        <div class="finding-section-label">Open Ports</div>
        <div class="table-wrap" style="margin-top:8px;">
          <table class="port-table">
            <thead>
              <tr>
                <th>Port</th><th>Protocol</th><th>Service</th><th>Version</th><th>State</th>
              </tr>
            </thead>
            <tbody>
              {% for port in tr.open_ports %}
              <tr>
                <td class="port-num">{{ port.port_number }}</td>
                <td style="color:var(--text3);">{{ port.protocol }}</td>
                <td class="port-service">{{ port.service_name or '—' }}</td>
                <td style="color:var(--text2);">{{ port.service_version or '—' }}</td>
                <td style="color:var(--text3);">{{ port.state }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endif %}

      {% if tr.findings %}
      <div class="finding-section">
        <div class="finding-section-label">Findings</div>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;">
          {% for finding in tr.findings %}
          <a href="#finding-{{ finding.id }}" class="meta-tag" style="background: var(--{{ finding.severity }}-bg); color: var(--{{ finding.severity }}); border-color: rgba({{ '239,68,68' if finding.severity == 'critical' else '249,115,22' if finding.severity == 'high' else '234,179,8' if finding.severity == 'medium' else '34,197,94' }}, 0.3); text-decoration: none;">
            {{ finding.title }}
          </a>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {% if not tr.open_ports and not tr.findings %}
      <div class="no-results" style="padding:20px;text-align:center;">No ports or findings for this target.</div>
      {% endif %}
    </div>
  </div>
  {% endfor %}
</section>

<!-- ════════════════════ 4. FINDINGS TABLE ════════════════════ -->
<section id="findings-table">
  <div class="section-header">
    <span class="section-number">04</span>
    <span class="section-title">Findings Table</span>
  </div>

  <div class="filter-bar">
    <button class="filter-btn active" id="filter-all" onclick="filterFindings('all')">All ({{ total_findings }})</button>
    {% if severity_counts.Critical %}<button class="filter-btn" id="filter-Critical" onclick="filterFindings('Critical')">Critical ({{ severity_counts.Critical }})</button>{% endif %}
    {% if severity_counts.High %}<button class="filter-btn" id="filter-High" onclick="filterFindings('High')">High ({{ severity_counts.High }})</button>{% endif %}
    {% if severity_counts.Medium %}<button class="filter-btn" id="filter-Medium" onclick="filterFindings('Medium')">Medium ({{ severity_counts.Medium }})</button>{% endif %}
    {% if severity_counts.Low %}<button class="filter-btn" id="filter-Low" onclick="filterFindings('Low')">Low ({{ severity_counts.Low }})</button>{% endif %}
    {% if severity_counts.Informational %}<button class="filter-btn" id="filter-Informational" onclick="filterFindings('Informational')">Info ({{ severity_counts.Informational }})</button>{% endif %}
    <select class="cat-select" id="cat-filter" onchange="filterFindingsByCat(this.value)">
      <option value="">All Categories</option>
      {% for cat in category_counts.keys() %}<option value="{{ cat }}">{{ cat }}</option>{% endfor %}
    </select>
    <input type="text" class="search-input" id="search-input" placeholder="Search target..." oninput="searchFindings(this.value)">
  </div>

  <div class="findings-table-wrap">
    <table class="findings-table" id="findings-table-el">
      <thead>
        <tr>
          <th>#</th><th>Severity</th><th>Title</th><th>Target</th><th>Port</th><th>Category</th><th>CVE</th>
        </tr>
      </thead>
      <tbody>
        {% for f in all_findings %}
        <tr class="finding-row" data-severity="{{ f.severity }}" data-category="{{ f.category }}" data-target="{{ f.target }}" onclick="scrollToFinding('{{ f.id }}')">
          <td style="font-family:'IBM Plex Mono',monospace;color:var(--text3);font-size:12px;">{{ loop.index }}</td>
          <td><span class="pill pill-{{ f.severity }}">{{ f.severity }}</span></td>
          <td class="f-title">{{ f.title }}</td>
          <td class="f-target">{{ f.target }}{% if f.port %}:{{ f.port }}{% endif %}</td>
          <td style="font-family:'IBM Plex Mono',monospace;color:var(--text3);font-size:12px;">{% if f.port %}{{ f.port }}{% else %}—{% endif %}</td>
          <td><span class="meta-tag">{{ f.category }}</span></td>
          <td class="f-cve">{% for cve in f.cve_ids[:2] %}<span style="color:var(--crit);">{{ cve }}</span>{% if not loop.last %}, {% endif %}{% endfor %}</td>
        </tr>
        {% else %}
        <tr><td colspan="7" class="no-results">No findings recorded.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<!-- ════════════════════ 5. DETAILED FINDINGS ════════════════════ -->
<section id="findings-detail">
  <div class="section-header">
    <span class="section-number">05</span>
    <span class="section-title">Detailed Findings</span>
  </div>

  {% for sev in severity_order %}
    {% set sev_findings = all_findings | selectattr('severity', 'eq', sev) | list %}
    {% if sev_findings %}
    <div style="margin-bottom:28px;">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
        <span class="pill pill-{{ sev }}" style="font-size:12px;">{{ sev }}</span>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text3);">{{ sev_findings|length }} finding{{ 's' if sev_findings|length != 1 }}</span>
      </div>
      {% for f in sev_findings %}
      <div class="finding-card" id="finding-{{ f.id }}">
        <div class="finding-card-header">
          <span class="pill pill-{{ f.severity }}">{{ f.severity }}</span>
          <div style="flex:1;">
            <div class="finding-card-title">{{ f.title }}</div>
            <div class="finding-card-meta">
              <span class="meta-tag host-tag">{{ f.target }}{% if f.port %}:{{ f.port }}{% endif %}</span>
              <span class="meta-tag">{{ f.category }}</span>
              {% if f.cvss_score %}<span class="cvss-badge cvss-{{ f.severity }}">CVSS {{ f.cvss_score }}</span>{% endif %}
              {% for cve in f.cve_ids %}<a href="https://nvd.nist.gov/vuln/detail/{{ cve }}" target="_blank" class="cve-link">{{ cve }}</a>{% endfor %}
            </div>
          </div>
        </div>
        <div class="finding-card-body">
          <div class="finding-section">
            <div class="finding-section-label">Description</div>
            <div class="finding-section-text">{{ f.description }}</div>
          </div>
          {% if f.evidence %}
          <div class="finding-section">
            <div class="finding-section-label">Evidence</div>
            <pre class="evidence-block">{{ f.evidence }}</pre>
          </div>
          {% endif %}
          <div class="finding-section">
            <div class="finding-section-label">Remediation</div>
            <div class="finding-section-text" style="white-space:pre-line;">{{ f.remediation }}</div>
          </div>
          {% if f.references %}
          <div class="finding-section">
            <div class="finding-section-label">References</div>
            <div style="display:flex;flex-direction:column;gap:4px;">
              {% for ref in f.references %}<a href="{{ ref }}" target="_blank" class="ref-link">{{ ref }}</a>{% endfor %}
            </div>
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  {% endfor %}

  {% if not all_findings %}
  <div class="no-results">◈ No findings recorded for this scan.</div>
  {% endif %}
</section>

<!-- ════════════════════ 6. SCREENSHOTS ════════════════════ -->
<section id="screenshots">
  <div class="section-header">
    <span class="section-number">06</span>
    <span class="section-title">Screenshots Gallery</span>
  </div>
  {% if screenshots %}
  <div class="screenshots-grid">
    {% for ss in screenshots %}
    <div class="screenshot-card">
      <div class="screenshot-header">
        <span class="screenshot-host">{{ ss.host }}</span>
        <span class="scheme-badge scheme-{{ ss.scheme }}">{{ ss.scheme|upper }}</span>
        {% if ss.status_code %}<span style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3);">HTTP {{ ss.status_code }}</span>{% endif %}
      </div>
      <div class="screenshot-meta">
        {% if ss.page_title %}Title: {{ ss.page_title }}<br>{% endif %}
        {% if ss.final_url %}URL: {{ ss.final_url }}{% endif %}
      </div>
      <div class="screenshot-img-wrap">
        {% if ss.encoded_image %}
          <img src="{{ ss.encoded_image }}" class="screenshot-img" alt="{{ ss.host }} {{ ss.scheme }}" loading="lazy">
        {% elif ss.error %}
          <div class="screenshot-error">⚠ {{ ss.error }}</div>
        {% else %}
          <div class="screenshot-error">No screenshot available</div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="no-results">No screenshots captured.</div>
  {% endif %}
</section>

<!-- ════════════════════ 7. CERTIFICATES ════════════════════ -->
<section id="certificates">
  <div class="section-header">
    <span class="section-number">07</span>
    <span class="section-title">Certificate Report</span>
  </div>
  {% if cert_data %}
  <div class="table-wrap">
    <table class="cert-table">
      <thead>
        <tr><th>Host</th><th>CN</th><th>Issuer</th><th>Expiry</th><th>Days Left</th><th>SANs</th><th>Issues</th></tr>
      </thead>
      <tbody>
        {% for c in cert_data %}
        <tr>
          <td>{{ c.host }}:{{ c.port }}</td>
          <td>{{ c.cn or '—' }}</td>
          <td style="color:var(--text2);">{{ c.issuer or '—' }}</td>
          <td class="{% if c.expired %}cert-expired{% elif c.days_left is not none and c.days_left < 30 %}cert-expiring{% elif c.days_left is not none and c.days_left < 90 %}cert-expiring-soon{% else %}cert-ok{% endif %}">
            {{ c.expiry[:10] if c.expiry else '—' }}
          </td>
          <td class="{% if c.expired %}cert-expired{% elif c.days_left is not none and c.days_left < 30 %}cert-expiring{% elif c.days_left is not none and c.days_left < 90 %}cert-expiring-soon{% else %}cert-ok{% endif %}">
            {% if c.days_left is not none %}{{ c.days_left }}d{% else %}—{% endif %}
          </td>
          <td>{{ c.sans_count }}</td>
          <td>
            {% if c.issues > 0 %}<span style="color:var(--crit);">{{ c.issues }} issue{{ 's' if c.issues != 1 }}</span>
            {% else %}<span style="color:var(--low);">Clean</span>{% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="no-results">No TLS certificates analyzed.</div>
  {% endif %}
</section>

<!-- ════════════════════ 8. SECURITY HEADERS ════════════════════ -->
<section id="headers">
  <div class="section-header">
    <span class="section-number">08</span>
    <span class="section-title">Security Headers Summary</span>
  </div>
  
  {% if headers_summary and (headers_summary.security_headers or headers_summary.info_disclosure_headers) %}
  
  <!-- Security Headers Overview Stats -->
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:15px;margin-bottom:25px;">
    <div class="stat-card">
      <div class="stat-label">Missing Security Headers</div>
      <div class="stat-value" style="color:var(--warn);">{{ headers_summary.security_headers.missing|length }}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Wrongly Configured</div>
      <div class="stat-value" style="color:var(--high);">{{ headers_summary.security_headers.wrongly_configured|length }}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Info Disclosure Headers</div>
      <div class="stat-value" style="color:var(--low);">{{ headers_summary.info_disclosure_headers.present|length }}</div>
    </div>
  </div>

  <!-- Missing Security Headers Table -->
  {% if headers_summary.security_headers.missing %}
  <div style="margin-bottom:30px;">
    <div style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px;text-transform:uppercase;letter-spacing:0.5px;">Missing Security Headers</div>
    <div class="table-wrap">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="border-bottom:2px solid var(--border);">
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Target</th>
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Header Name</th>
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Severity</th>
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Description</th>
          </tr>
        </thead>
        <tbody>
          {% for item in headers_summary.security_headers.missing %}
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:10px;color:var(--accent2);font-weight:500;">{{ item.target }}</td>
            <td style="padding:10px;color:var(--accent2);font-weight:500;">{{ item.header }}</td>
            <td style="padding:10px;">
              <span style="display:inline-block;padding:3px 8px;border-radius:3px;font-size:11px;font-weight:600;background:{{ 
                'rgba(220,38,38,0.1)'  if item.severity == 'Critical' else
                'rgba(234,88,12,0.1)'  if item.severity == 'High' else
                'rgba(217,119,6,0.1)'  if item.severity == 'Medium' else
                'rgba(101,163,13,0.1)' 
              }};color:{{ 
                'var(--crit)' if item.severity == 'Critical' else
                'var(--high)' if item.severity == 'High' else
                'var(--warn)' if item.severity == 'Medium' else
                'var(--low)'
              }};">{{ item.severity }}</span>
            </td>
            <td style="padding:10px;color:var(--text3);font-size:12px;">{{ item.description|truncate(60) }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}

  <!-- Wrongly Configured Headers Table -->
  {% if headers_summary.security_headers.wrongly_configured %}
  <div style="margin-bottom:30px;">
    <div style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px;text-transform:uppercase;letter-spacing:0.5px;">Wrongly Configured Headers</div>
    <div class="table-wrap">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="border-bottom:2px solid var(--border);">
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Target</th>
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Configuration Issue</th>
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Severity</th>
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Description</th>
          </tr>
        </thead>
        <tbody>
          {% for item in headers_summary.security_headers.wrongly_configured %}
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:10px;color:var(--accent2);font-weight:500;">{{ item.target }}</td>
            <td style="padding:10px;color:var(--accent2);font-weight:500;">{{ item.header }}</td>
            <td style="padding:10px;">
              <span style="display:inline-block;padding:3px 8px;border-radius:3px;font-size:11px;font-weight:600;background:{{ 
                'rgba(220,38,38,0.1)'  if item.severity == 'Critical' else
                'rgba(234,88,12,0.1)'  if item.severity == 'High' else
                'rgba(217,119,6,0.1)'  if item.severity == 'Medium' else
                'rgba(101,163,13,0.1)' 
              }};color:{{ 
                'var(--crit)' if item.severity == 'Critical' else
                'var(--high)' if item.severity == 'High' else
                'var(--warn)' if item.severity == 'Medium' else
                'var(--low)'
              }};">{{ item.severity }}</span>
            </td>
            <td style="padding:10px;color:var(--text3);font-size:12px;">{{ item.description|truncate(60) }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}

  <!-- Information Disclosure Headers Table -->
  {% if headers_summary.info_disclosure_headers.present %}
  <div>
    <div style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px;text-transform:uppercase;letter-spacing:0.5px;">Information Disclosure Headers</div>
    <div class="table-wrap">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="border-bottom:2px solid var(--border);">
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Target</th>
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Header Name</th>
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Severity</th>
            <th style="text-align:left;padding:10px;color:var(--text2);font-weight:600;font-size:12px;">Information Disclosed</th>
          </tr>
        </thead>
        <tbody>
          {% for item in headers_summary.info_disclosure_headers.present %}
          <tr style="border-bottom:1px solid var(--border);">
            <td style="padding:10px;color:var(--accent2);font-weight:500;">{{ item.target }}</td>
            <td style="padding:10px;color:var(--accent2);font-weight:500;">{{ item.header }}</td>
            <td style="padding:10px;">
              <span style="display:inline-block;padding:3px 8px;border-radius:3px;font-size:11px;font-weight:600;background:{{ 
                'rgba(220,38,38,0.1)'  if item.severity == 'Critical' else
                'rgba(234,88,12,0.1)'  if item.severity == 'High' else
                'rgba(217,119,6,0.1)'  if item.severity == 'Medium' else
                'rgba(101,163,13,0.1)' 
              }};color:{{ 
                'var(--crit)' if item.severity == 'Critical' else
                'var(--high)' if item.severity == 'High' else
                'var(--warn)' if item.severity == 'Medium' else
                'var(--low)'
              }};">{{ item.severity }}</span>
            </td>
            <td style="padding:10px;color:var(--text3);font-size:12px;">{{ item.value_hint|truncate(80) }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}

  {% else %}
  <div class="no-results">No security header data available.</div>
  {% endif %}
</section>

<!-- ════════════════════ 9. PORT SUMMARY ════════════════════ -->
<section id="ports">
  <div class="section-header">
    <span class="section-number">09</span>
    <span class="section-title">Port Scan Summary</span>
  </div>
  {% if port_data %}
    {% for host_data in port_data %}
    <div class="port-accordion" id="port-{{ loop.index }}" onclick="toggleAccordion('port-{{ loop.index }}')">
      <div class="port-accordion-header">
        <span>
          <span style="color:var(--accent2);">{{ host_data.host }}</span>
          <span style="color:var(--text3);margin-left:12px;font-size:11px;">{{ host_data.ports|length }} port{{ 's' if host_data.ports|length != 1 }}</span>
        </span>
        <span class="port-accordion-arrow">▶</span>
      </div>
      <div class="port-accordion-body">
        <table class="port-table">
          <thead><tr><th>Port</th><th>Protocol</th><th>Service</th><th>Version</th><th>Banner</th></tr></thead>
          <tbody>
            {% for p in host_data.ports %}
            <tr>
              <td class="port-num">{{ p.port }}</td>
              <td style="color:var(--text3);">{{ p.proto }}</td>
              <td class="port-service">{{ p.service or '—' }}</td>
              <td style="color:var(--text2);">{{ p.version or '—' }}</td>
              <td style="color:var(--text3);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{ p.banner }}">{{ p.banner or '—' }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    {% endfor %}
  {% else %}
  <div class="no-results">No port data available.</div>
  {% endif %}
</section>

<!-- ════════════════════ 10. APPENDIX ════════════════════ -->
<section id="appendix">
  <div class="section-header">
    <span class="section-number">10</span>
    <span class="section-title">Appendix</span>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px;">
    <div class="chart-card">
      <div class="chart-title">Scan Configuration</div>
      <table style="width:100%;border-collapse:collapse;">
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;width:140px;">Scan ID</td><td style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text2);">{{ scan_id[:16] }}...</td></tr>
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;">Profile</td><td style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text);">{{ profile|upper }}</td></tr>
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;">Started</td><td style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text2);">{{ started_at }}</td></tr>
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;">Finished</td><td style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text2);">{{ finished_at }}</td></tr>
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;">Duration</td><td style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text);">{{ duration }}</td></tr>
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;">Tool Version</td><td style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--accent2);">RECON-X v{{ tool_version }}</td></tr>
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;">Generated</td><td style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text2);">{{ generated_at }}</td></tr>
      </table>
    </div>
    <div class="chart-card">
      <div class="chart-title">Target Summary</div>
      <table style="width:100%;border-collapse:collapse;">
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;width:120px;">Total Targets</td><td style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text);">{{ total_targets }}</td></tr>
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;">Alive</td><td style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--low);">{{ alive_targets }}</td></tr>
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;">Risk Score</td><td style="font-family:'IBM Plex Mono',monospace;font-size:14px;font-weight:600;color:var(--crit);">{{ risk_score }} / 100</td></tr>
        <tr><td style="padding:6px 0;color:var(--text3);font-family:'IBM Plex Mono',monospace;font-size:12px;">Risk Rating</td><td><span class="pill pill-{{ overall_risk }}">{{ overall_risk }}</span></td></tr>
      </table>
    </div>
  </div>

  <!-- Target list -->
  <div style="margin-bottom:16px;font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;">Complete Target List</div>
  <div class="table-wrap">
    <table class="findings-table">
      <thead><tr><th>Host</th><th>IP</th><th>Status</th><th>Duration</th><th>Open Ports</th><th>Findings</th></tr></thead>
      <tbody>
        {% for t in target_statuses %}
        <tr>
          <td style="font-family:'IBM Plex Mono',monospace;color:var(--text);">{{ t.host }}</td>
          <td style="font-family:'IBM Plex Mono',monospace;color:var(--text2);font-size:12px;">{{ t.ip or '—' }}</td>
          <td><span class="status-badge status-{{ t.status }}">{{ t.status }}</span></td>
          <td style="font-family:'IBM Plex Mono',monospace;color:var(--text3);font-size:12px;">{{ t.duration }}</td>
          <td style="font-family:'IBM Plex Mono',monospace;color:var(--accent2);">{{ t.open_ports }}</td>
          <td style="font-family:'IBM Plex Mono',monospace;{% if t.findings > 0 %}color:var(--crit);{% else %}color:var(--text3);{% endif %}">{{ t.findings }}</td>
        </tr>
        {% else %}
        <tr><td colspan="6" class="no-results">No targets.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

</div><!-- /content -->
</div><!-- /main -->
</div><!-- /layout -->

<script>
// ── Chart data ────────────────────────────────────────────────
const CHARTS = {{ charts_json | safe }};

function patchCallbacks(cfg) {
  // Convert string callback definitions to functions
  if (cfg && cfg.options) {
    const str = JSON.stringify(cfg);
    // We'll mount charts directly
  }
  return cfg;
}

window.addEventListener('DOMContentLoaded', () => {
  // Severity pie
  const ctxSev = document.getElementById('chart-severity');
  if (ctxSev) {
    new Chart(ctxSev, CHARTS.severity_pie);
  }
  // Category bar
  const ctxCat = document.getElementById('chart-category');
  if (ctxCat) {
    new Chart(ctxCat, CHARTS.category_bar);
  }
  // Host bar
  const ctxHost = document.getElementById('chart-hosts');
  if (ctxHost) {
    new Chart(ctxHost, CHARTS.host_bar);
  }

  // Count-up animation
  document.querySelectorAll('.count-up').forEach(el => {
    const target = parseInt(el.dataset.target, 10);
    if (!target) return;
    let current = 0;
    const step = Math.ceil(target / 40);
    const timer = setInterval(() => {
      current = Math.min(current + step, target);
      el.textContent = current;
      if (current >= target) clearInterval(timer);
    }, 20);
  });

  // Sidebar active link tracking
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-item');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(link => {
          link.classList.toggle('active', link.getAttribute('href') === '#' + entry.target.id);
        });
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });
  sections.forEach(s => observer.observe(s));
});

// ── Filtering ────────────────────────────────────────────────
let currentSeverity = 'all';
let currentCategory = '';
let currentSearch = '';

function applyFilters() {
  const rows = document.querySelectorAll('.finding-row');
  rows.forEach(row => {
    const sev = row.dataset.severity;
    const cat = row.dataset.category;
    const tgt = (row.dataset.target || '').toLowerCase();
    const sevOk = currentSeverity === 'all' || sev === currentSeverity;
    const catOk = !currentCategory || cat === currentCategory;
    const searchOk = !currentSearch || tgt.includes(currentSearch.toLowerCase());
    row.classList.toggle('hidden', !(sevOk && catOk && searchOk));
  });
}

function filterFindings(sev) {
  currentSeverity = sev;
  document.querySelectorAll('[id^="filter-"]').forEach(btn => {
    btn.classList.remove('active', 'active-crit', 'active-high', 'active-med', 'active-low', 'active-info');
  });
  const btn = document.getElementById('filter-' + sev);
  if (btn) {
    btn.classList.add('active');
    if (sev !== 'all') btn.classList.add('active-' + sev.toLowerCase().slice(0,4));
  }
  applyFilters();
}

function filterFindingsByCat(cat) {
  currentCategory = cat;
  applyFilters();
}

function searchFindings(query) {
  currentSearch = query;
  applyFilters();
}

function scrollToFinding(id) {
  const el = document.getElementById('finding-' + id);
  if (el) { el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
}

// ── Port accordions ──────────────────────────────────────────
function toggleAccordion(id) {
  const el = document.getElementById(id);
  if (el) el.classList.toggle('open');
}
</script>
</body>
</html>
